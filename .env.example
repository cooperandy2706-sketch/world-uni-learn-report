# world-uni-learn-report/.env.example
# Copy this file to .env and fill in your values.

# ============================================
# Supabase
# ============================================
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
VITE_SUPABASE_ANON_KEY=<anon-key>

# ============================================
# Push Notifications (VAPID)
# ============================================
VITE_VAPID_PUBLIC_KEY=<vapid-public-key>

# ============================================
# AI Features (Google Gemini)
# ============================================
VITE_GEMINI_API_KEY=<gemini-api-key>

# ============================================
# App
# ============================================
VITE_APP_NAME=World Uni-Learn Report
VITE_APP_URL=http://localhost:5173

# ============================================
# SMS – Arkesel (SUPABASE EDGE FUNCTION SECRET)
# ============================================
# ⚠️  ARKESEL_API_KEY must NOT go here.
#     Store it as a Supabase Edge Function Secret:
#
#   Supabase Dashboard → Project Settings →
#   Edge Functions → Secrets → Add new secret
#
#   Key:   ARKESEL_API_KEY
#   Value: <your key from https://sms.arkesel.com>
#
#   Sender ID (configured in edge function): ESTEVROYAL
#   Message prefix (auto-applied):           "ESTEV ROYAL: "
#   Batch size per request:                  50 recipients
